```

## 7. 功能测试（必须执行）

安装完成后需要进行实际功能测试，验证写入和搜索是否正常工作：

### 7.1 创建测试脚本

```bash
cat > /home/node/.openclaw/workspace/tmp/test-memory.js << 'EOF'
/**
 * Test script for memory-lancedb plugin functionality
 */

import { randomUUID } from "node:crypto";
import fs from "node:fs";
import lancedb from "/home/node/.openclaw/npm/node_modules/@lancedb/lancedb/dist/index.js";
import OpenAI from "/home/node/.openclaw/npm/node_modules/openai/index.mjs";

const config = JSON.parse(fs.readFileSync("/home/node/.openclaw/openclaw.json", "utf8"));
const memoryConfig = config.plugins.entries["memory-lancedb"].config;
const dbPath = "/home/node/.openclaw/memory/lancedb";
const TABLE_NAME = "memories";

async function testLanceDBConnection() {
  console.log("=== Testing LanceDB Connection ===\n");
  const db = await lancedb.connect(dbPath);
  console.log("✅ Connected to LanceDB successfully");
  const tables = await db.tableNames();
  console.log(`📋 Tables in database: ${JSON.stringify(tables)}`);
  let table;
  if (tables.includes(TABLE_NAME)) {
    table = await db.openTable(TABLE_NAME);
    console.log("✅ Opened existing table");
  } else {
    const schemaData = [{
      id: "__init__",
      text: "initialization record",
      vector: Array.from({ length: memoryConfig.embedding.dimensions }).fill(0),
      importance: 0,
      category: "test",
      createdAt: Date.now(),
    }];
    table = await db.createTable(TABLE_NAME, schemaData);
    await table.delete('id = "__init__"');
    console.log("✅ Created new table");
  }
  const count = await table.countRows();
  console.log(`📊 Current row count: ${count}`);
  return { db, table };
}

async function testEmbeddingGeneration(openai) {
  console.log("\n=== Testing Embedding Generation ===\n");
  const response = await openai.embeddings.create({
    model: memoryConfig.embedding.model,
    input: "这是一条测试记忆，用于测试 memory-lancedb 插件功能是否正常",
    dimensions: memoryConfig.embedding.dimensions,
  });
  const embedding = response.data[0].embedding;
  console.log(`✅ Generated embedding successfully`);
  console.log(`📊 Embedding dimensions: ${embedding.length}`);
  console.log(`📊 Expected dimensions: ${memoryConfig.embedding.dimensions}`);
  if (embedding.length !== memoryConfig.embedding.dimensions) {
    throw new Error(`Dimension mismatch: got ${embedding.length}, expected ${memoryConfig.embedding.dimensions}`);
  }
  return embedding;
}

async function testInsertMemory(table, embedding) {
  console.log("\n=== Testing Memory Insertion ===\n");
  const testEntry = {
    id: randomUUID(),
    text: "这是一条测试记忆，创建于 " + new Date().toISOString(),
    vector: embedding,
    importance: 5,
    category: "test",
    createdAt: Date.now(),
  };
  await table.add([testEntry]);
  console.log(`✅ Inserted test memory successfully`);
  console.log(`📝 Memory: ${testEntry.text}`);
  console.log(`🔑 ID: ${testEntry.id}`);
  const newCount = await table.countRows();
  console.log(`📊 New row count: ${newCount}`);
  return testEntry;
}

async function testVectorSearch(table, embedding) {
  console.log("\n=== Testing Vector Search ===\n");
  const results = await table.search(embedding).limit(5).toArray();
  console.log(`✅ Vector search completed successfully`);
  console.log(`🔍 Found ${results.length} results`);
  results.forEach((result, index) => {
    const score = result.score ?? result._distance ?? 0;
    console.log(`\n${index + 1}. [score/distance: ${score ? score.toFixed(4) : 'N/A'}]`);
    console.log(`   ID: ${result.id}`);
    console.log(`   Text: ${result.text}`);
    console.log(`   Category: ${result.category}`);
    console.log(`   Importance: ${result.importance}`);
  });
  return results;
}

async function testMultipleMemories(table, openai) {
  console.log("\n=== Testing Multiple Memories ===\n");
  const testTexts = [
    "HanMing 喜欢测试开源项目和阅读源代码",
    "OpenClaw 是一个个人人工智能助手框架",
    "memory-lancedb 使用 LanceDB 作为向量数据库",
    "企业微信插件提供了通讯录、文档、待办等功能集成",
  ];
  for (const text of testTexts) {
    const response = await openai.embeddings.create({
      model: memoryConfig.embedding.model,
      input: text,
      dimensions: memoryConfig.embedding.dimensions,
    });
    const entry = {
      id: randomUUID(),
      text,
      vector: response.data[0].embedding,
      importance: 3,
      category: "test",
      createdAt: Date.now(),
    };
    await table.add([entry]);
    console.log(`✅ Added: "${text}"`);
  }
  const finalCount = await table.countRows();
  console.log(`\n📊 Final row count: ${finalCount}`);
}

async function testSemanticSearch(table, openai, query) {
  console.log(`\n=== Testing Semantic Search: "${query}" ===\n`);
  const response = await openai.embeddings.create({
    model: memoryConfig.embedding.model,
    input: query,
    dimensions: memoryConfig.embedding.dimensions,
  });
  const queryEmbedding = response.data[0].embedding;
  const results = await table.search(queryEmbedding).limit(3).toArray();
  console.log(`✅ Semantic search completed`);
  console.log(`🔍 Top ${results.length} results:\n`);
  results.forEach((result, index) => {
    const score = result.score ?? result._distance ?? 0;
    console.log(`${index + 1}. [score/distance: ${score ? score.toFixed(4) : 'N/A'}] "${result.text}"`);
  });
  return results;
}

async function main() {
  console.log("Starting memory-lancedb functionality test...\n");
  const openai = new OpenAI({
    apiKey: memoryConfig.embedding.apiKey,
    baseURL: memoryConfig.embedding.baseUrl,
  });
  const { db, table } = await testLanceDBConnection();
  const firstEmbedding = await testEmbeddingGeneration(openai);
  await testInsertMemory(table, firstEmbedding);
  await testMultipleMemories(table, openai);
  await testVectorSearch(table, firstEmbedding);
  await testSemanticSearch(table, openai, "框架功能测试");
  await testSemanticSearch(table, openai, "阅读代码");
  await testSemanticSearch(table, openai, "向量数据库存储");
  console.log("\n🎉 All tests completed successfully!");
  console.log("memory-lancedb plugin is working correctly.\n");
  await db.close();
}

main().catch(err => {
  console.error("\n❌ Test failed:", err);
  process.exit(1);
});
EOF
